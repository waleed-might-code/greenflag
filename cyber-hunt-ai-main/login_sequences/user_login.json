{
  "name": "user_login_with_2fa",
  "role": "user",
  "steps": [
    {
      "action": "navigate",
      "url": "https://example.com/login",
      "timeout_ms": 30000,
      "description": "Navigate to login page",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "fill",
      "selector": "#username",
      "value_ref": "{{username}}",
      "timeout_ms": 5000,
      "description": "Fill username",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "fill",
      "selector": "#password",
      "value_ref": "{{password}}",
      "timeout_ms": 5000,
      "description": "Fill password",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "click",
      "selector": "button.login-btn",
      "timeout_ms": 5000,
      "description": "Click login",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "manual_pause",
      "description": "Complete 2FA verification (60 seconds)",
      "required": false,
      "retry_count": 0
    },
    {
      "action": "wait_for_selector",
      "selector": ".dashboard-container",
      "timeout_ms": 70000,
      "description": "Wait for dashboard after 2FA",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "extract_cookies",
      "description": "Extract session cookies",
      "required": true,
      "retry_count": 0
    },
    {
      "action": "extract_token",
      "token_name": "auth_token",
      "token_source": "localstorage",
      "description": "Extract auth token from localStorage",
      "required": false,
      "retry_count": 0
    }
  ],
  "success_indicators": [
    {
      "type": "url_contains",
      "value": "/dashboard"
    },
    {
      "type": "selector_exists",
      "value": ".dashboard-container"
    }
  ],
  "created_at": "2024-01-15T10:00:00Z",
  "updated_at": "2024-01-15T10:00:00Z",
  "metadata": {
    "description": "User login with 2FA manual step",
    "requires_manual_intervention": true,
    "tested": true
  }
}
